Protocol: GetPublicKey

Types:
  Agent A, IDP, X;
  Number Fresh;
  Function pk;

Knowledge:
  A: A, IDP, pk(IDP), X;
  IDP: A, IDP, X, pk(IDP), pk(X), pk(A);

Actions:
  A -> IDP: A, X, Fresh
  IDP -> A: {| X, pk(X), Fresh |} pk(IDP)

Goals:
  A authenticates IDP on Fresh
  Fresh secret between A, IDP