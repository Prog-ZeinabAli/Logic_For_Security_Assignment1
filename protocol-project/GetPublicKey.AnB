(*
  GetPublicKey Protocol (Week 4)
  Separate protocol: A asks IDP for public key of another party.
  A initially knows only pk(IDP).
*)

Protocol GetPublicKey

Types:
  Agent A, IDP, X;

Knowledge:
  A: A, IDP, pk(IDP), X;
  IDP: A, IDP, sk(IDP), pk(IDP), pk(X);
  X: X, sk(X), pk(X), pk(IDP);

Actions:
  A -> IDP: A, X, Fresh;
  IDP -> A: {X, pk(X), Fresh}inv(sk(IDP));

Goals:
  A authenticates IDP on Fresh;
  A secret Fresh;
